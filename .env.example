# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=put_your_bot_token_here

# Application / client ID from the Discord developer portal
CLIENT_ID=put_your_client_id_here

# Your test server ID. Commands are registered to this server for fast updates.
GUILD_ID=put_your_server_id_here

# Private staff channel where FAPD logs join flags and scan results.
MOD_LOG_CHANNEL_ID=put_your_private_mod_log_channel_id_here

# Rotector config.
ROTECTOR_API_BASE=https://roscoe.rotector.com

# Optional. Leave blank if your Rotector API access does not require a key.
ROTECTOR_API_KEY=

# Flexible auth support in case Rotector gives you a specific header style.
# Common examples:
# ROTECTOR_AUTH_HEADER=Authorization
# ROTECTOR_AUTH_PREFIX=Bearer 
# or:
# ROTECTOR_AUTH_HEADER=x-api-key
# ROTECTOR_AUTH_PREFIX=
ROTECTOR_AUTH_HEADER=Authorization
ROTECTOR_AUTH_PREFIX=Bearer 

# Bot behavior. Keep this as log until you trust your results.
# Options: log, timeout, kick, ban
ACTION_MODE=log

# Timeout length if ACTION_MODE=timeout.
TIMEOUT_MINUTES=60

# Whether /check replies should be private by default.
EPHEMERAL_COMMANDS=true
